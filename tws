#!/usr/bin/env bash
# tws — timewarrior session wrapper
# Usage:
#   tws start <tag>      start a new tracked session (prepends entry to note file)
#   tws continue [tag]   resume the current session (no new entry added)
#   tws stop             emergency stop if nvim exits without cleaning up
#
# Quitting nvim ends the session: annotates the timewarrior interval and stops the timer.
# tws stop is an emergency escape hatch if nvim exits without cleaning up.

set -euo pipefail

NOTES_DIR="${TWS_NOTES:-$HOME/Documents/Notes}"

# ── helpers ──────────────────────────────────────────────────────────────────

_active_tag() {
    timew 2>/dev/null | awk '/^Tracking/{print $2; exit}'
}

_note_file() {
    echo "$NOTES_DIR/$1.md"
}

_prepend_entry() {
    local file
    file="$(_note_file "$1")"
    mkdir -p "$NOTES_DIR"

    # Skip if today's date is already the latest entry
    local today
    today="$(date '+%a %d %b %Y')"
    if [[ -f "$file" ]] && head -1 "$file" | grep -q "^$today"; then
        return
    fi

    local header
    header="$(date '+%a %d %b %Y %H:%M:%S %Z')"$'\n- \n'
    if [[ -f "$file" ]]; then
        local existing
        existing="$(cat "$file")"
        printf '%s\n%s' "$header" "$existing" > "$file"
    else
        printf '%s' "$header" > "$file"
    fi
}

_end_session() {
    local note_file="$1"
    timew annotate @1 "$(cat "$note_file")"
    timew stop
    echo "Stopped."
}

# ── nvim layout ──────────────────────────────────────────────────────────────

_open_nvim() {
    local main_file="$1"
    nvim "$main_file" \
        -c "nnoremap ZZ :wqa!<CR>" \
        -c "botright 5split" \
        -c "setlocal nonumber norelativenumber statusline=\ ⏱\ session\\ timer" \
        -c "terminal watch -n1 timew" \
        -c "wincmd k"
}

# ── commands ─────────────────────────────────────────────────────────────────

cmd_start() {
    local tag="${1:?Usage: tws start <tag>}"
    tag="$(tr '[:upper:]' '[:lower:]' <<< "$tag")"

    local active
    active="$(_active_tag)" || true
    [[ -z "$active" ]] || { echo "Session already running: $active. Stop it first."; exit 1; }

    local note_file
    note_file="$(_note_file "$tag")"
    _prepend_entry "$tag"

    timew start "$tag"

    _open_nvim "$note_file"

    _end_session "$note_file"
}

cmd_continue() {
    local tag="${1:-}"
    tag="$(tr '[:upper:]' '[:lower:]' <<< "$tag")"

    local note_file
    if [[ -n "$tag" ]]; then
        note_file="$(_note_file "$tag")"
        [[ -f "$note_file" ]] || { echo "No notes found for '$tag'."; exit 1; }
    else
        tag="$(_active_tag)" || true
        [[ -n "$tag" ]] || { echo "No active session and no tag given."; exit 1; }
        note_file="$(_note_file "$tag")"
    fi

    timew annotate @1 "$(cat "$note_file")" 2>/dev/null || true
    timew start "$tag"
    echo "Continuing: $tag"

    _open_nvim "$note_file"

    _end_session "$note_file"
}

cmd_stop() {
    local tag
    tag="$(_active_tag)" || true
    [[ -n "$tag" ]] || { echo "No active session."; exit 1; }

    local note_file
    note_file="$(_note_file "$tag")"
    if [[ -f "$note_file" ]]; then
        timew annotate @1 "$(cat "$note_file")"
    fi

    timew stop
    echo "Stopped: $tag"
}

# ── dispatch ─────────────────────────────────────────────────────────────────

case "${1:-}" in
    start)    shift; cmd_start "$@" ;;
    continue) shift; cmd_continue "$@" ;;
    stop)     cmd_stop ;;
    *)
        if [[ -n "${1:-}" ]]; then
            cmd_start "$@"
        else
            echo "Usage: tws [start|continue|stop] <tag>"
            exit 1
        fi
        ;;
esac
